APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

AWS_ENDPOINT=
AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# AI / LLM
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# SMS / Voice
SMS_ENABLED=false
SMS_DEFAULT_GATEWAY=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
EMERGENCY_VOICE_ENABLED=false

# Push Notifications
PUSH_ENABLED=false

# Alerts
ALERTS_APPROVAL_REQUIRED=true
ALERTS_SMS_ENABLED=false

# IPAWS
IPAWS_ENABLED=false
IPAWS_ENDPOINT=
IPAWS_COG_ID=

# Email Gateway
EMAIL_ENABLED=true
EMAIL_PROVIDER=postal
EMAIL_DEFAULT_GATEWAY=postal
EMAIL_FAILOVER_GATEWAY=
EMAIL_FALLBACK_PROVIDER=
POSTAL_API_URL=
POSTAL_SERVER_KEY=
POSTAL_DEFAULT_IP_POOL=
POSTAL_WEBHOOK_SECRET=
POSTMARK_API_KEY=
POSTMARK_MESSAGE_STREAM_ID=
RESEND_API_KEY=
SENDGRID_API_KEY=

# Slack
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# Rate Limiting
RATE_LIMITING_ENABLED=true

# EMAIL PLATFORM
EMAIL_PLATFORM_ENABLED=true

# Postal Pool — Transactional
POSTAL_TRANSACTIONAL_API_URL=https://postal.fibonacco.com
POSTAL_TRANSACTIONAL_API_KEY=
POSTAL_TRANSACTIONAL_SMTP_HOST=postal.fibonacco.com
POSTAL_TRANSACTIONAL_SMTP_PORT=587
POSTAL_TRANSACTIONAL_SMTP_USER=
POSTAL_TRANSACTIONAL_SMTP_PASS=

# Postal Pool — Broadcast
POSTAL_BROADCAST_API_URL=https://postal.fibonacco.com
POSTAL_BROADCAST_API_KEY=
POSTAL_BROADCAST_SMTP_HOST=postal.fibonacco.com
POSTAL_BROADCAST_SMTP_PORT=587
POSTAL_BROADCAST_SMTP_USER=
POSTAL_BROADCAST_SMTP_PASS=

# Postal Pool — SMB Campaign
POSTAL_SMB_CAMPAIGN_API_URL=https://postal.fibonacco.com
POSTAL_SMB_CAMPAIGN_API_KEY=

# Webhook security
POSTAL_WEBHOOK_SIGNING_KEY=

# Rate limiting
EMAIL_RATE_TRANSACTIONAL_PER_MINUTE=500
EMAIL_RATE_BROADCAST_PER_MINUTE=2000
EMAIL_RATE_SMB_PER_MINUTE=1000

# ZeroBounce Email Validation
ZEROBOUNCE_API_KEY=
ZEROBOUNCE_BASE_URL=https://api.zerobounce.net/v2

# --- Multisite publishing bridge (CC ↔ Day.News) ---
# Same bearer secret on Multisite for /api/v1/bridge/*; base URL is the Multisite app origin (no trailing slash).
PUBLISHING_BRIDGE_API_KEY=<shared_key>
PUBLISHING_BRIDGE_BASE_URL=<multisite_url>

# Platform tenant for system-owned templates and bridge-imported leads
FIBONACCO_SYSTEM_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Stripe: community subscription recurring Price IDs (Dashboard → Products → Price → price_…) ---
STRIPE_PRICE_COMMUNITY_INFLUENCER=price_xxx
STRIPE_PRICE_COMMUNITY_EXPERT=price_xxx
STRIPE_PRICE_COMMUNITY_SPONSOR=price_xxx
STRIPE_PRICE_COMMUNITY_REPORTER=price_xxx

# --- DB bootstrap (from backend/) ---
# php artisan migrate
# php artisan db:seed --class=ProductCatalogSeeder
# php artisan db:seed --class=SlotLimitSeeder
# SlotLimitSeeder applies caps per row in `communities`; re-run after communities exist.
