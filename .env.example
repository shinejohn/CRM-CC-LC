# API Configuration (Command Center)
# THE CONVENTION: VITE_API_URL is the API origin INCLUDING `/api` but NOT `/v1`.
# All request paths in code start with `/v1/...` (e.g. POST .../api/v1/auth/login).
# Set this to the API origin + `/api` in every environment (never append `/v1`).
VITE_API_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# Stripe (publishable key for frontend Elements)
VITE_STRIPE_KEY=pk_test_your_key_here

# Real-time (optional - when set, requires laravel-echo + pusher-js)
# VITE_PUSHER_APP_KEY=
# VITE_PUSHER_APP_CLUSTER=us2
